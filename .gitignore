# ═══════════════════════════════════════════
#  SARC — .gitignore
# ═══════════════════════════════════════════

# ── Sistema operativo ───────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs y editores ──────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── PHP / Backend ────────────────────────────
# Archivos de configuración local (contienen credenciales)
api/config.local.php
api/config.php
.env
.env.local
.env.production

# Logs de PHP
*.log
php_errors.log
error_log

# ── Node.js (si se usan herramientas de build) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package.json
package-lock.json

# ── Archivos temporales / caché ──────────────
*.tmp
*.temp
*.cache
.sass-cache/
dist/
build/

# ── Archivos comprimidos generados ───────────
*.zip
*.rar
*.tar
*.tar.gz
*.7z

# ── Base de datos — respaldos locales ────────
# (se excluyen respaldos pero se mantiene el schema inicial)
backups/
*.sql.bak
*_backup.sql
*_dump.sql

# ── Uploads de usuario ───────────────────────
uploads/
storage/

# ── Archivos de despliegue ───────────────────
deploy.sh
*.pem
*.key
*.crt

# ── XAMPP / Laragon / WAMP ───────────────────
# No subir configuraciones específicas del servidor local
apache/
httpd.conf
php.ini
