                  "});",
                  "",
                  "pm.test('TC-AUTH-001-T4: Cuerpo contiene campo data', () => {",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('TC-AUTH-001-T5: data.username coincide con el enviado', () => {",
                  "    pm.expect(jsonData.data.username).to.eql('admin1');",
                  "});",
                  "",
                  "pm.test('TC-AUTH-001-T6: data.rol es admin', () => {",
                  "    pm.expect(jsonData.data.rol).to.eql('admin');",
                  "});",
                  "",
                  "pm.test('TC-AUTH-001-T7: data.estado es activo', () => {",
                  "    pm.expect(jsonData.data.estado).to.eql('activo');",
                  "});",
